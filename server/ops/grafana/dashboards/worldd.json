{
  "uid": "meridian-worldd",
  "title": "worldd (simulation)",
  "tags": ["meridian", "ops-05", "v1", "worldd"],
  "schemaVersion": 39,
  "version": 1,
  "editable": false,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "realm",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "meridian-prometheus" },
        "query": "label_values(meridian_ccu, realm)",
        "includeAll": true,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 200,
      "title": "Tick loop",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 1,
      "title": "Map tick p50 / p99 (per zone/shard)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "meridian-prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum by (le, zone, shard) (rate(meridian_tick_duration_seconds_bucket{realm=~\"$realm\"}[5m])))", "legendFormat": "p50 {{zone}}/{{shard}}" },
        { "refId": "B", "expr": "histogram_quantile(0.99, sum by (le, zone, shard) (rate(meridian_tick_duration_seconds_bucket{realm=~\"$realm\"}[5m])))", "legendFormat": "p99 {{zone}}/{{shard}}" }
      ]
    },
    {
      "id": 2,
      "title": "Tick throughput (ticks/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "meridian-prometheus" },
      "description": "Rate of tick observations = effective tick frequency per zone/shard.",
      "fieldConfig": { "defaults": { "unit": "hertz" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (zone, shard) (rate(meridian_tick_duration_seconds_count{realm=~\"$realm\"}[5m]))", "legendFormat": "{{zone}}/{{shard}}" }
      ]
    },
    {
      "id": 201,
      "title": "Movement validation",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "id": 3,
      "title": "Movement violations by kind",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "meridian-prometheus" },
      "description": "kind ∈ {speed, teleport, bounds, z} — the M0 validator taxonomy (world_metrics.h move_reject_kind).",
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (kind) (rate(meridian_movement_violations_total{realm=~\"$realm\"}[5m]))", "legendFormat": "{{kind}}" }
      ]
    },
    {
      "id": 4,
      "title": "Snap-back corrections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "meridian-prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (zone, shard) (rate(meridian_movement_corrections_total{realm=~\"$realm\"}[5m]))", "legendFormat": "{{zone}}/{{shard}}" }
      ]
    },
    {
      "id": 202,
      "title": "Area of interest & load",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }
    },
    {
      "id": 5,
      "title": "AoI entities per map",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "meridian-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "max by (map, zone, shard) (meridian_aoi_entities{realm=~\"$realm\"})", "legendFormat": "{{map}} {{zone}}/{{shard}}" }
      ]
    },
    {
      "id": 6,
      "title": "Opcode rate (top 10)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "meridian-prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "topk(10, sum by (opcode) (rate(meridian_opcode_total{realm=~\"$realm\"}[5m])))", "legendFormat": "{{opcode}}" }
      ]
    },
    {
      "id": 203,
      "title": "IO-worker saturation (max CCU/worldd ≈ io_workers — #278)",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 }
    },
    {
      "id": 7,
      "title": "IO-worker utilization (busy / pool)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "meridian-prometheus" },
      "description": "worldd serves each connection start-to-finish on one blocking IO worker; the pool auto-sizes to cores−3 (override --io-workers N). busy/pool ≈ 1 means every worker is in-flight and new connections wait in the accept backlog. Emitted live from meridian_io_workers_busy / meridian_io_workers (#278/#297).",
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 0.9 } ] } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "max by (process) (meridian_io_workers_busy{realm=~\"$realm\", process=\"worldd\"} / meridian_io_workers{realm=~\"$realm\", process=\"worldd\"})", "legendFormat": "utilization" }
      ]
    },
    {
      "id": 8,
      "title": "Connection churn (accepted / closed)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "meridian-prometheus" },
      "description": "process=\"worldd\" isolates worldd's connection lifecycle from authd's.",
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(rate(meridian_connections_accepted_total{realm=~\"$realm\", process=\"worldd\"}[5m]))", "legendFormat": "accepted/s" },
        { "refId": "B", "expr": "sum(rate(meridian_connections_closed_total{realm=~\"$realm\", process=\"worldd\"}[5m]))", "legendFormat": "closed/s" }
      ]
    },
    {
      "id": 9,
      "title": "IO-workers: busy vs pool size (#278)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "meridian-prometheus" },
      "description": "Raw in-flight worker count vs configured pool size. When 'busy' meets 'pool size' the pool is saturated (new connections queue in the accept backlog). Operators MUST set --io-workers ≥ expected concurrent players (do not rely on the cores−3 auto-default for capacity — #278).",
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "max by (process) (meridian_io_workers_busy{realm=~\"$realm\", process=\"worldd\"})", "legendFormat": "busy" },
        { "refId": "B", "expr": "max by (process) (meridian_io_workers{realm=~\"$realm\", process=\"worldd\"})", "legendFormat": "pool size" }
      ]
    },
    {
      "id": 11,
      "title": "CCU per shard (load context)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "meridian-prometheus" },
      "description": "Concurrent connected users per zone/shard. At M0 max concurrent CCU per worldd ≈ io_workers, so read this alongside the IO-worker utilization panel above.",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (zone, shard) (meridian_ccu{realm=~\"$realm\"})", "legendFormat": "CCU {{zone}}/{{shard}}" }
      ]
    },
    {
      "id": 10,
      "title": "DB latency p99 + RSS",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "meridian-prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [ { "matcher": { "id": "byFrameRefID", "options": "B" }, "properties": [ { "id": "unit", "value": "bytes" } ] } ] },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.99, sum by (le, db) (rate(meridian_db_latency_seconds_bucket{realm=~\"$realm\"}[5m])))", "legendFormat": "db p99 {{db}}" },
        { "refId": "B", "expr": "max (meridian_rss_bytes{realm=~\"$realm\", process=\"worldd\"})", "legendFormat": "worldd RSS" }
      ]
    }
  ]
}
