{
  "uid": "meridian-realm-health",
  "title": "Realm health",
  "tags": ["meridian", "ops-05", "v1"],
  "schemaVersion": 39,
  "version": 1,
  "editable": false,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "realm",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "meridian-prometheus" },
        "query": "label_values(meridian_ccu, realm)",
        "includeAll": true,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Tick p99 (per map)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "meridian-prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (le, zone, shard) (rate(meridian_tick_duration_seconds_bucket{realm=~\"$realm\"}[5m])))",
          "legendFormat": "{{zone}}/{{shard}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "CCU",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "meridian-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (realm) (meridian_ccu{realm=~\"$realm\"})",
          "legendFormat": "{{realm}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Opcode rate (top 10)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "meridian-prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (opcode) (rate(meridian_opcode_total{realm=~\"$realm\"}[5m])))",
          "legendFormat": "{{opcode}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "DB latency p99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "meridian-prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "description": "DB write-queue depth is not charted at M0: the DB layer is synchronous with no queue to measure (#297). A queue-depth signal returns with the async DB worker-pool at M1.",
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (le, db) (rate(meridian_db_latency_seconds_bucket{realm=~\"$realm\"}[5m])))",
          "legendFormat": "latency {{db}}"
        }
      ]
    }
  ]
}
