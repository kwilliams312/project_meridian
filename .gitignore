# --- Claude Code local artifacts (machine-specific; never committed) ---
# Per-machine settings override, agent worktrees, and any ephemeral run state a
# tool created while cwd was under .claude/. Team-shared assets (.claude/skills/,
# .claude/rules/, .claude/commands/, .claude/agents/) are NOT ignored and may be
# committed deliberately.
.claude/settings.local.json
.claude/worktrees/
.claude/.dev-run/

# Python (validator tooling)
__pycache__/
*.pyc
.venv/
.pytest_cache/

# mcc build cache (tools SAD §2.8)
.mcc-cache/

# --- Native macOS dev toolkit (scripts/dev/, issue #223) ---
# CMake build trees produced by scripts/dev/build.sh
/build/
# Headless bot build tree produced by scripts/dev/demo-networked.sh (-DMERIDIAN_BOT=ON)
/build-client-bot/
# Throwaway local MariaDB datadirs + runtime state (scripts/dev/test.sh --db,
# scripts/dev/run-local.sh). NEVER committed — ephemeral local state only.
/.dev-run/
# Self-signed TLS cert/key generated for local run (scripts/dev/run-local.sh)
scripts/dev/certs/*.crt
scripts/dev/certs/*.key

# Discord webhook URL for scripts/dev/post-update.sh (never commit)
.discord-webhook

# --- Client GDExtension build artifacts (issue #158) ---
# Godot editor cache
.godot/
# Pinned engine binaries fetched by scripts/fetch-deps.sh (never committed)
client/.godot-bin/
# CMake / SCons build trees (incl. per-target dirs, e.g. build-ext / build-tests)
client/build/
client/build-*/
client/.sconsign.dblite
# Compiled GDExtension output (dropped into client/project/bin/ by the build)
client/project/bin/libmeridian.*
# Godot 4.7 per-resource UID sidecars — regenerated on every editor import (the
# #283 windowed seed). Machine-local, none tracked; res:// paths are the source of
# truth for our scenes, so these are cache, not content (like .godot/).
client/project/**/*.uid
# --- Forge forge_core GDExtension build artifacts (issue #134) ---
# CMake build trees + compiled output (dropped into forge/project/bin/ by the build)
client/gdextension/forge_core/build/
client/gdextension/forge_core/build-*/
client/forge/project/bin/libforge_core.*
# Godot editor cache for the Forge tool project
client/forge/project/.godot/
# Object / intermediate files
*.o
*.obj
*.os
*.lo
*.a
*.dll
*.dylib
*.so
*.pdb
*.exp
*.ilk
*.gen.cpp

# --- Deploy: local TLS certs for the reference compose (#177) ---
# Per-deployment secrets — never committed. The certs/ dir + its README are
# tracked; the actual key/cert material is not.
deploy/docker/certs/*.crt
deploy/docker/certs/*.key
deploy/docker/certs/*.pem

# --- Strudel render cache (generated; #410) ---
# tools/strudel_render writes its content-addressed render cache to `.render-cache/`
# relative to CWD. scripts/content-build.sh and the content-ci strudel-render job run
# the renderer from the repo root (its `--all` glob is CWD-relative), so the cache
# lands here. Transient build state — never committed.
/.render-cache/

# --- Strudel-rendered music stems (generated artifacts; #410) ---
# The zone-01 adaptive stem WAVs are RENDERED from their committed .strudel
# sources by tools/strudel_render (in CI via scripts/content-build.sh and the
# content-ci strudel-render job) — sources-only policy: the .strudel patterns and
# .render.yaml manifests ARE committed, the derived WAVs are not.
content/core/assets/audio/mus/zone01/*.wav
