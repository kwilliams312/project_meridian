; Project Meridian — Forge editor-tool Godot project (issue #134 skeleton).
;
; Forge is the in-Godot terrain/world-building EditorPlugin (Tools SAD §5). This
; is a DEDICATED, minimal Godot project that hosts the meridian_forge addon in
; ISOLATION from the game client (client/project) — enabling/building Forge cannot
; touch or break the client boot. Engine pinned to 4.7-stable (client/ENGINE_VERSION).
;
; At M1, per SAD §5 ("ships inside the game's Godot project") the addon folds into
; the client project; this standalone project is the M0 de-risk host that keeps the
; skeleton isolated per the #134 scope note.
;
; The meridian_forge plugin is enabled below, so opening this project in the Godot
; editor loads Forge: the Zone dock, the ForgeZoneMarker custom node, and its gizmo.
; Requires the forge_core GDExtension binary (forge/project/bin/) — build it first:
;   cd client/gdextension/forge_core
;   cmake -B build -DGODOTCPP_TARGET=editor && cmake --build build -j

config_version=5

[application]

config/name="Project Meridian — Forge (skeleton)"
config/features=PackedStringArray("4.7", "Forward Plus")

[editor_plugins]

enabled=PackedStringArray("res://addons/meridian_forge/plugin.cfg")

[rendering]

; Forward+ per TD-02: native Metal on macOS Apple Silicon (the #134 de-risk box),
; D3D12 on Windows (Forge's shipped platform, TD-08).
renderer/rendering_method="forward_plus"
