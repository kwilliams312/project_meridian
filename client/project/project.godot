; Meridian client — Godot project (bootstrap skeleton, issue #158).
; Engine pinned to 4.7-stable (client/ENGINE_VERSION). Filled out by later
; milestone work (scenes/ui/net/sim/stream/datastore per Client SAD §2). This
; bootstrap project exists so the placeholder GDExtension can be loaded and its
; MeridianClient.get_version() verified from the editor / --headless.

config_version=5

[application]

config/name="Project Meridian (client bootstrap)"
config/features=PackedStringArray("4.7", "Forward Plus")
; Boot entry of the client flow (Boot/Login → CharSelect → World). The login scene
; (#99) is the first screen; on success it hands off to char-select (#110), which
; enters the world map. Requires the GDExtension binary (login uses MeridianLogin);
; char-select itself is pure GDScript.
run/main_scene="res://scenes/login/login_screen.tscn"

[rendering]

; Forward+ per TD-02: D3D12 on Windows, native Metal on macOS Apple Silicon.
renderer/rendering_method="forward_plus"
; Required for the macOS **arm64** export (#113). Godot refuses an arm64/universal
; export unless the ETC2/ASTC VRAM-compression import path is enabled (arm64 is
; treated as a mobile-class texture target). Benign for the desktop dev boot — it
; only widens which compressed texture variants the importer emits.
textures/vram_compression/import_etc2_astc=true
