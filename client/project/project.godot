; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Project Meridian (client bootstrap)"
run/main_scene="res://scenes/login/login_screen.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")

[autoload]

; MeridianContentDB (#477): the client read side of mcc-built pack content —
; appearance catalogs, item worn data, dye colors, asset paths. Loaded at boot from
; res://meridian/core. Consumers (char-create pickers, the spec-② assembler) do NOT
; use the bare autoload name — standalone --script verify runs have no autoloads —
; they preload res://content/content_db.gd and call .instance(), which returns this
; autoload in the running app (see content_db.gd's ACCESS PATTERN header).
ContentDB="*res://content/content_db.gd"

[rendering]

textures/vram_compression/import_etc2_astc=true
