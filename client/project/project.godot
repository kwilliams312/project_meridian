; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Project Meridian (client bootstrap)"
run/main_scene="res://scenes/login/login_screen.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")

[autoload]

; MeridianContentDB (#477): the client read side of mcc-built pack content —
; appearance catalogs, item worn data, dye colors, asset paths. Loaded at boot from
; res://meridian/core. Consumers (char-create pickers, the spec-② assembler) do NOT
; use the bare autoload name — standalone --script verify runs have no autoloads —
; they preload res://content/content_db.gd and call .instance(), which returns this
; autoload in the running app (see content_db.gd's ACCESS PATTERN header).
ContentDB="*res://content/content_db.gd"

[display]

; #630: grow the base window ~50% over the Godot default (1152×648 → 1728×972) so
; character-select (and the other Control scenes) open larger, and scale the whole UI
; — fonts + the char-select paperdoll SubViewportContainer — proportionally as the
; window resizes. `canvas_items` renders the 2D canvas at the base resolution then
; scales it to the window; `expand` keeps the base scale without distortion (extra
; area on off-aspect windows instead of letterboxing). All client scenes use responsive
; anchor/container layouts, so the scaled canvas keeps its layout; the world's 3D
; content renders into the same base viewport and is unaffected functionally.
window/size/viewport_width=1728
window/size/viewport_height=972
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]

textures/vram_compression/import_etc2_astc=true
