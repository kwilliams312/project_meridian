; SPDX-License-Identifier: Apache-2.0
;
; Project Meridian — minimal character-select scene (issue #110, CHR-01 / D-11).
; A plain Control tree wired to char_select.gd: an account label, a character list
; with Enter World / Delete actions, and a create panel (name + race + class pickers)
; alongside the shared placeholder-model preview (built in code by the script). Nodes
; use unique names (%Name) so the script's @onready lookups resolve regardless of layout.
; Intentionally minimal — the #110 deliverable is the char-select FLOW, not skinned UI.

[gd_scene load_steps=2 format=3 uid="uid://bmeridiancharsel110"]

[ext_resource type="Script" path="res://scenes/charselect/char_select.gd" id="1_charsel"]

[node name="CharSelect" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1_charsel")

[node name="Root" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 24.0
offset_top = 24.0
offset_right = -24.0
offset_bottom = -24.0

[node name="Title" type="Label" parent="Root"]
layout_mode = 2
text = "Project Meridian — Character Select"

[node name="AccountLabel" type="Label" parent="Root"]
unique_name_in_owner = true
layout_mode = 2
text = "Account:"

[node name="Body" type="HBoxContainer" parent="Root"]
layout_mode = 2
size_flags_vertical = 3

[node name="ListPanel" type="VBoxContainer" parent="Root/Body"]
layout_mode = 2
size_flags_horizontal = 3

[node name="ListLabel" type="Label" parent="Root/Body/ListPanel"]
layout_mode = 2
text = "Your characters"

[node name="CharList" type="ItemList" parent="Root/Body/ListPanel"]
unique_name_in_owner = true
layout_mode = 2
size_flags_vertical = 3

[node name="ListActions" type="HBoxContainer" parent="Root/Body/ListPanel"]
layout_mode = 2

[node name="EnterWorldButton" type="Button" parent="Root/Body/ListPanel/ListActions"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
disabled = true
text = "Enter World"

[node name="DeleteButton" type="Button" parent="Root/Body/ListPanel/ListActions"]
unique_name_in_owner = true
layout_mode = 2
disabled = true
text = "Delete"

[node name="CreatePanel" type="VBoxContainer" parent="Root/Body"]
layout_mode = 2
size_flags_horizontal = 3

[node name="CreateLabel" type="Label" parent="Root/Body/CreatePanel"]
layout_mode = 2
text = "Create a character"

[node name="NameEdit" type="LineEdit" parent="Root/Body/CreatePanel"]
unique_name_in_owner = true
layout_mode = 2
max_length = 32
placeholder_text = "Character name"

[node name="RaceLabel" type="Label" parent="Root/Body/CreatePanel"]
layout_mode = 2
text = "Race"

[node name="RaceOption" type="OptionButton" parent="Root/Body/CreatePanel"]
unique_name_in_owner = true
layout_mode = 2

[node name="ClassLabel" type="Label" parent="Root/Body/CreatePanel"]
layout_mode = 2
text = "Class"

[node name="ClassOption" type="OptionButton" parent="Root/Body/CreatePanel"]
unique_name_in_owner = true
layout_mode = 2

[node name="CreateButton" type="Button" parent="Root/Body/CreatePanel"]
unique_name_in_owner = true
layout_mode = 2
text = "Create"

[node name="PreviewLabel" type="Label" parent="Root/Body/CreatePanel"]
layout_mode = 2
text = "Placeholder model (shared)"

[node name="PreviewHolder" type="Control" parent="Root/Body/CreatePanel"]
unique_name_in_owner = true
custom_minimum_size = Vector2(180, 220)
layout_mode = 2

[node name="StatusLabel" type="Label" parent="Root"]
unique_name_in_owner = true
layout_mode = 2
autowrap_mode = 2
text = ""
