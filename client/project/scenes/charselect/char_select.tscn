; SPDX-License-Identifier: Apache-2.0
;
; Project Meridian — character-select scene (issue #110 origin, redesigned in #639).
; The CONTROLLER + ROSTER VIEW: a plain Control tree wired to char_select.gd. %RosterView
; holds the character list, the SELECTED character's paperdoll (built in code into
; %PreviewHolder), and three actions — Enter Realm / Create New Character / Delete. The
; creation form is NO LONGER here: "Create New Character" reveals the separate
; character_create.tscn full-rect over this view (#639). Nodes use unique names (%Name)
; so the script's @onready lookups resolve regardless of layout.

[gd_scene load_steps=3 format=3 uid="uid://bmeridiancharsel110"]

[ext_resource type="Script" path="res://scenes/charselect/char_select.gd" id="1_charsel"]

; #630: a scoped Theme raising the default font size so every Label/Button/OptionButton
; in this scene reads comfortably at the larger window (Godot's default is 16). Applied
; on the root CharSelect Control only, so it cascades to this scene alone (login / world
; HUD are untouched). Under the project's `canvas_items` stretch it scales with the window.
[sub_resource type="Theme" id="Theme_charsel630"]
default_font_size = 20

[node name="CharSelect" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
theme = SubResource("Theme_charsel630")
script = ExtResource("1_charsel")

[node name="RosterView" type="VBoxContainer" parent="."]
unique_name_in_owner = true
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 16.0
offset_top = 16.0
offset_right = -16.0
offset_bottom = -16.0

[node name="Title" type="Label" parent="RosterView"]
layout_mode = 2
text = "Project Meridian — Character Select"

[node name="AccountLabel" type="Label" parent="RosterView"]
unique_name_in_owner = true
layout_mode = 2
text = "Account:"

[node name="Body" type="HBoxContainer" parent="RosterView"]
layout_mode = 2
size_flags_vertical = 3

[node name="ListPanel" type="VBoxContainer" parent="RosterView/Body"]
layout_mode = 2
size_flags_horizontal = 3

[node name="ListLabel" type="Label" parent="RosterView/Body/ListPanel"]
layout_mode = 2
text = "Your characters"

[node name="CharList" type="ItemList" parent="RosterView/Body/ListPanel"]
unique_name_in_owner = true
layout_mode = 2
size_flags_vertical = 3

[node name="PreviewPanel" type="VBoxContainer" parent="RosterView/Body"]
layout_mode = 2
size_flags_horizontal = 3

[node name="PreviewLabel" type="Label" parent="RosterView/Body/PreviewPanel"]
layout_mode = 2
horizontal_alignment = 1
text = "Selected character"

[node name="PreviewHolder" type="Control" parent="RosterView/Body/PreviewPanel"]
unique_name_in_owner = true
custom_minimum_size = Vector2(260, 290)
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3

[node name="ListActions" type="HBoxContainer" parent="RosterView"]
layout_mode = 2

[node name="EnterWorldButton" type="Button" parent="RosterView/ListActions"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
disabled = true
text = "Enter Realm"

[node name="CreateNewButton" type="Button" parent="RosterView/ListActions"]
unique_name_in_owner = true
layout_mode = 2
text = "Create New Character"

[node name="DeleteButton" type="Button" parent="RosterView/ListActions"]
unique_name_in_owner = true
layout_mode = 2
disabled = true
text = "Delete"

[node name="StatusLabel" type="Label" parent="RosterView"]
unique_name_in_owner = true
layout_mode = 2
autowrap_mode = 2
text = ""
