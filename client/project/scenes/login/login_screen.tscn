; SPDX-License-Identifier: Apache-2.0
;
; Project Meridian — minimal login screen scene (issue #99).
; A plain Control tree wired to login_screen.gd: host/port/account/password
; fields, a Login button, and a status label. Intentionally minimal — the #99
; deliverable is the login FLOW + net core, not skinned UI (a later UI story
; skins this). Nodes use unique names (%Name) so the script's @onready lookups
; resolve regardless of layout.

[gd_scene load_steps=3 format=3 uid="uid://bmeridianlogin099"]

[ext_resource type="Script" path="res://scenes/login/login_screen.gd" id="1_login"]

; #645 (was #638): a scoped Theme raising the default font size so every Label /
; LineEdit / Button on this screen reads comfortably in the large #630 1728×972 window.
; Godot's default is 16; #638 bumped it to 20, but on-device that still read small and
; lost in the window — #645 raises the field/button/label default to 26 (with a larger
; per-control Title, see below). Applied on the root LoginScreen Control only, so it
; cascades to this scene alone (world HUD untouched). Under the project's `canvas_items`
; stretch it scales with the window, so the login card grows/shrinks on resize (#630).
[sub_resource type="Theme" id="Theme_login638"]
default_font_size = 26

[node name="LoginScreen" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
theme = SubResource("Theme_login638")
script = ExtResource("1_login")

; #645 (was #638): the login form is a fixed-size card centered in the window
; (anchor 0.5/0.5), NOT stretched edge-to-edge. #638's 480×360 read tiny in the
; 1728×972 window (~28% wide, lost in dead space), so #645 grows it to 900×620 —
; ~52% of the width and ~64% of the height, a comfortably-proportioned share that
; is still clearly a centered, bounded card. `separation` spaces the rows so they
; breathe in the taller card; `alignment = 1` centers them vertically. Under
; `canvas_items` stretch the whole card scales with the window on resize (#630).
[node name="VBox" type="VBoxContainer" parent="."]
unique_name_in_owner = true
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -450.0
offset_top = -310.0
offset_right = 450.0
offset_bottom = 310.0
theme_override_constants/separation = 20
alignment = 1

[node name="Title" type="Label" parent="VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 42
horizontal_alignment = 1
text = "Project Meridian — Login"

[node name="HostEdit" type="LineEdit" parent="VBox"]
unique_name_in_owner = true
layout_mode = 2
text = "127.0.0.1"
placeholder_text = "Login server host"

[node name="PortEdit" type="LineEdit" parent="VBox"]
unique_name_in_owner = true
layout_mode = 2
text = "7100"
placeholder_text = "Port (IF-1 default 7100)"

[node name="AccountEdit" type="LineEdit" parent="VBox"]
unique_name_in_owner = true
layout_mode = 2
placeholder_text = "Account"

[node name="PasswordEdit" type="LineEdit" parent="VBox"]
unique_name_in_owner = true
layout_mode = 2
secret = true
placeholder_text = "Password"

[node name="LoginButton" type="Button" parent="VBox"]
unique_name_in_owner = true
layout_mode = 2
text = "Login"

[node name="StatusLabel" type="Label" parent="VBox"]
unique_name_in_owner = true
layout_mode = 2
autowrap_mode = 2
text = ""
