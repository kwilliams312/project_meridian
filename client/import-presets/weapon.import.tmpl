; meridian import preset — weapon (Art PRD §2.1, Art SAD §2.3)
; Applies to IF-8 class: weapon_model (sm_* weapon meshes, bone-attached).
; A weapon is a static mesh attached to a character bone attachment — it moves with the
; animated character, so it is NOT a lightmapped static: no lightmap UV2, no occluder,
; no static collision. LOD0-2 hand-authored (small silhouettes), importer LODs OFF.
[params]

meshes/lightmap_texel_size=0.2
meshes/generate_lods=false
meshes/create_shadow_meshes=true
meshes/ensure_tangents=true
meshes/light_baking=0
_subresources={}
