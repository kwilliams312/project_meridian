; meridian import preset — prop (Art SAD §2.3)
; Applies to IF-8 class: prop (sm_prop_*, small clutter).
; Importer-generated LODs ALLOWED (PRD §2.1 — the one static class Godot may auto-LOD),
; UV2 on, shadow-mesh simplification on. MultiMesh-batched when repeated (PRD §2.5).
[params]

meshes/lightmap_texel_size=0.4
meshes/generate_lods=true
meshes/create_shadow_meshes=true
meshes/ensure_tangents=true
meshes/light_baking=2
_subresources={}
