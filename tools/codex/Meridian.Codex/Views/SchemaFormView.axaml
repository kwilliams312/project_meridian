<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sf="using:Meridian.Codex.SchemaForms"
             xmlns:views="using:Meridian.Codex.Views"
             x:Class="Meridian.Codex.Views.SchemaFormView"
             x:DataType="sf:SchemaFormViewModel">
  <ScrollViewer>
    <ItemsControl ItemsSource="{Binding Root.Children}" Margin="16">
      <ItemsControl.ItemTemplate>
        <DataTemplate x:DataType="sf:SchemaFieldViewModel">
          <views:SchemaFieldView />
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>
  </ScrollViewer>
</UserControl>
