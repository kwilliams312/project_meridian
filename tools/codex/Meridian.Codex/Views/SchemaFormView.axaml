<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sf="using:Meridian.Codex.SchemaForms"
             xmlns:views="using:Meridian.Codex.Views"
             x:Class="Meridian.Codex.Views.SchemaFormView"
             x:DataType="sf:SchemaFormViewModel">
  <ScrollViewer Background="{DynamicResource CodexWorkspaceBrush}">
    <Border x:Name="SchemaEditorSheet" Classes="card" Margin="28" MaxWidth="960" HorizontalAlignment="Stretch">
      <ItemsControl ItemsSource="{Binding Root.Children}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="sf:SchemaFieldViewModel">
            <views:SchemaFieldView />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </Border>
  </ScrollViewer>
</UserControl>
