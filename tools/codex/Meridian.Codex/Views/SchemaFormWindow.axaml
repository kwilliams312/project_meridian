<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sf="using:Meridian.Codex.SchemaForms"
        xmlns:views="using:Meridian.Codex.Views"
        xmlns:controls="using:Meridian.Codex.Controls"
        xmlns:auto="using:Avalonia.Automation"
        x:Class="Meridian.Codex.Views.SchemaFormWindow"
        x:DataType="sf:SchemaFormFileViewModel"
        Width="1100" Height="800" MinWidth="520" MinHeight="520"
        Title="{Binding Header}">
  <DockPanel>
    <Border DockPanel.Dock="Top" Classes="toolbar">
      <Grid ColumnDefinitions="*">
        <StackPanel Spacing="3">
          <TextBlock Text="{Binding Header}" FontSize="20" FontWeight="SemiBold" />
          <TextBlock Classes="muted" Text="{Binding FilePath}" FontSize="12" TextTrimming="CharacterEllipsis" />
        </StackPanel>
      </Grid>
    </Border>
    <StackPanel DockPanel.Dock="Bottom">
      <Border Classes="status-bar">
        <StackPanel Spacing="3">
          <TextBlock Text="{Binding Status}" />
          <TextBlock Classes="validation-error" Text="{Binding ValidationSummary}"
                     auto:AutomationProperties.Name="Validation summary" auto:AutomationProperties.HelpText="{Binding ValidationSummary}"
                     auto:AutomationProperties.LiveSetting="Assertive" />
        </StackPanel>
      </Border>
      <controls:EditorActionBar ActionText="Save content file"
                                ActionCommand="{Binding SaveCommand}"
                                IsActionEnabled="{Binding CanSave}"
                                StateDescription="{Binding SaveStateDescription}"
                                auto:AutomationProperties.Name="Save content file"
                                auto:AutomationProperties.HelpText="{Binding SaveStateDescription}"
                                auto:AutomationProperties.ItemStatus="{Binding SaveStateDescription}" />
    </StackPanel>
    <views:SchemaFormView DataContext="{Binding Form}" />
  </DockPanel>
</Window>
