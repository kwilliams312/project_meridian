<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Meridian.Codex.ViewModels"
             mc:Ignorable="d" d:DesignWidth="640" d:DesignHeight="700"
             x:Class="Meridian.Codex.Views.ItemEditorView"
             x:DataType="vm:ItemEditorViewModel">

  <UserControl.Styles>
    <Style Selector="TextBlock.section">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,12,0,4" />
    </Style>
    <Style Selector="TextBlock.field">
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Margin" Value="0,0,8,0" />
    </Style>
  </UserControl.Styles>

  <DockPanel>

    <!-- Command + file bar. -->
    <Border DockPanel.Dock="Top" Padding="8" Background="{DynamicResource SystemControlBackgroundListLowBrush}">
      <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto">
        <Button Content="_New" Command="{Binding NewCommand}" Margin="0,0,8,0"
                AutomationProperties.Name="New item" />
        <Button Grid.Column="1" Content="_Open…" Command="{Binding OpenCommand}" Margin="0,0,8,0"
                AutomationProperties.Name="Open item file"
                AutomationProperties.HelpText="Choose a Meridian item YAML file using the system file picker." />
        <Button Grid.Column="2" Content="_Save" Command="{Binding SaveCommand}" Margin="0,0,8,0"
                AutomationProperties.Name="Save item" />
        <TextBlock Grid.Column="3" Text="{Binding DisplayPath}" TextTrimming="CharacterEllipsis" Margin="0,0,8,0"
                   VerticalAlignment="Center" ToolTip.Tip="{Binding FilePath}"
                   AutomationProperties.Name="Selected item file"
                   AutomationProperties.HelpText="The compact selected path. Use Copy full path to access the complete location." />
        <Button Grid.Column="4" Content="Copy full path" Command="{Binding CopyFullPathCommand}"
                AutomationProperties.Name="Copy full item path" />
      </Grid>
    </Border>

    <!-- Validation + status bar. -->
    <Border DockPanel.Dock="Bottom" Padding="8,4" Background="{DynamicResource SystemControlBackgroundListLowBrush}">
      <StackPanel Spacing="2">
        <TextBlock Text="{Binding StatusText}" />
        <TextBlock Text="{Binding ValidationMessage}" FontSize="11" Opacity="0.8" TextWrapping="Wrap" />
      </StackPanel>
    </Border>

    <Grid ColumnDefinitions="*,320">

      <!-- Form. -->
      <ScrollViewer Grid.Column="0" Padding="16">
        <StackPanel Spacing="4">

          <TextBlock Classes="section" Text="Identity / classification" />
          <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Classes="field" Text="ID" />
            <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding Id}" />
            <TextBlock Grid.Row="1" Grid.Column="0" Classes="field" Text="Name" />
            <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding Name}" />
            <TextBlock Grid.Row="2" Grid.Column="0" Classes="field" Text="Flavor text" />
            <TextBox   Grid.Row="2" Grid.Column="1" AcceptsReturn="True" TextWrapping="Wrap"
                       Height="52" Text="{Binding FlavorText}" />
            <TextBlock Grid.Row="3" Grid.Column="0" Classes="field" Text="Class / subclass" />
            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Spacing="8">
              <ComboBox Width="150" ItemsSource="{Binding ItemClasses}" SelectedItem="{Binding ItemClass}" />
              <TextBox Width="150" Watermark="subclass" Text="{Binding Subclass}" />
            </StackPanel>
            <TextBlock Grid.Row="4" Grid.Column="0" Classes="field" Text="Equip type" />
            <TextBox   Grid.Row="4" Grid.Column="1" Watermark="equip_type reference" Text="{Binding EquipType}" />
            <TextBlock Grid.Row="5" Grid.Column="0" Classes="field" Text="Slot" />
            <ComboBox  Grid.Row="5" Grid.Column="1" HorizontalAlignment="Left" Width="150"
                       ItemsSource="{Binding Slots}" SelectedItem="{Binding Slot}" />
            <TextBlock Grid.Row="6" Grid.Column="0" Classes="field" Text="Rarity" />
            <ComboBox  Grid.Row="6" Grid.Column="1" HorizontalAlignment="Left" Width="150"
                       ItemsSource="{Binding Rarities}" SelectedItem="{Binding Rarity}" />
            <TextBlock Grid.Row="7" Grid.Column="0" Classes="field" Text="Req / item level" />
            <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal" Spacing="8">
              <TextBox Width="80" Watermark="req lvl" Text="{Binding RequiredLevel}" />
              <TextBox Width="80" Watermark="item lvl" Text="{Binding ItemLevel}" />
            </StackPanel>
            <TextBlock Grid.Row="8" Grid.Column="0" Classes="field" Text="Binding / stack" />
            <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal" Spacing="8">
              <ComboBox Width="130" ItemsSource="{Binding Bindings}" SelectedItem="{Binding Binding}" />
              <TextBox Width="80" Watermark="stack" Text="{Binding StackSize}" />
              <CheckBox Content="Unique" IsChecked="{Binding Unique}" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Grid.Row="9" Grid.Column="0" Classes="field" Text="Icon / model" />
            <StackPanel Grid.Row="9" Grid.Column="1" Orientation="Horizontal" Spacing="8">
              <TextBox Width="180" Watermark="icon art ref" Text="{Binding VisualIcon}" />
              <TextBox Width="180" Watermark="model art ref" Text="{Binding VisualModel}" />
            </StackPanel>
          </Grid>

          <TextBlock Classes="section" Text="Stats" />
          <ItemsControl ItemsSource="{Binding Stats}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:ItemStatRowViewModel">
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
                  <ComboBox Width="140"
                            ItemsSource="{Binding $parent[ItemsControl].((vm:ItemEditorViewModel)DataContext).StatKeys}"
                            SelectedItem="{Binding Stat}" />
                  <TextBox Width="90" Watermark="amount" Text="{Binding Amount}" />
                  <Button Content="✕"
                          Command="{Binding $parent[ItemsControl].((vm:ItemEditorViewModel)DataContext).RemoveStatCommand}"
                          CommandParameter="{Binding}" />
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <Button Content="+ Add stat" Command="{Binding AddStatCommand}" HorizontalAlignment="Left" />

          <TextBlock Classes="section" Text="Weapon / armor" />
          <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Classes="field" Text="Damage (min / max)" />
            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="8">
              <TextBox Width="80" Text="{Binding WeaponDamageMin}" />
              <TextBox Width="80" Text="{Binding WeaponDamageMax}" />
            </StackPanel>
            <TextBlock Grid.Row="1" Grid.Column="0" Classes="field" Text="Speed (ms) / school" />
            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="8">
              <TextBox Width="90" Watermark="speed" Text="{Binding WeaponSpeedMs}" />
              <ComboBox Width="130" ItemsSource="{Binding Schools}" SelectedItem="{Binding WeaponSchool}" />
            </StackPanel>
            <TextBlock Grid.Row="2" Grid.Column="0" Classes="field" Text="Armor" />
            <TextBox   Grid.Row="2" Grid.Column="1" Width="100" HorizontalAlignment="Left" Text="{Binding Armor}" />
          </Grid>

          <TextBlock Classes="section" Text="Worn (equipped render)" />
          <TextBlock Text="Models" FontWeight="SemiBold" Margin="0,4,0,4" />
          <ItemsControl ItemsSource="{Binding WornModels}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:ItemWornModelRowViewModel">
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
                  <TextBox Width="220" Watermark="model art ref" Text="{Binding Model}" />
                  <ComboBox Width="90"
                            ItemsSource="{Binding $parent[ItemsControl].((vm:ItemEditorViewModel)DataContext).Mirrors}"
                            SelectedItem="{Binding Mirror}" />
                  <Button Content="✕"
                          Command="{Binding $parent[ItemsControl].((vm:ItemEditorViewModel)DataContext).RemoveWornModelCommand}"
                          CommandParameter="{Binding}" />
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <Button Content="+ Add worn model" Command="{Binding AddWornModelCommand}" HorizontalAlignment="Left" />
          <Grid ColumnDefinitions="140,*" RowDefinitions="Auto" Margin="0,8,0,0">
            <TextBlock Grid.Row="0" Grid.Column="0" Classes="field" Text="Attach / sheath" />
            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="8">
              <ComboBox Width="130" ItemsSource="{Binding AttachSockets}" SelectedItem="{Binding WornAttachSocket}" />
              <ComboBox Width="130" ItemsSource="{Binding AttachSockets}" SelectedItem="{Binding WornSheathSocket}" />
            </StackPanel>
          </Grid>
          <TextBlock Text="Hides (armor geosets)" FontWeight="SemiBold" Margin="0,8,0,4" />
          <ItemsControl ItemsSource="{Binding WornHides}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:ItemWornTokenRowViewModel">
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
                  <ComboBox Width="140"
                            ItemsSource="{Binding $parent[ItemsControl].((vm:ItemEditorViewModel)DataContext).GeosetRegions}"
                            SelectedItem="{Binding Token}" />
                  <Button Content="✕"
                          Command="{Binding $parent[ItemsControl].((vm:ItemEditorViewModel)DataContext).RemoveWornHideCommand}"
                          CommandParameter="{Binding}" />
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <Button Content="+ Add hidden geoset" Command="{Binding AddWornHideCommand}" HorizontalAlignment="Left" />
          <TextBlock Text="Dye channels" FontWeight="SemiBold" Margin="0,8,0,4" />
          <ItemsControl ItemsSource="{Binding WornDyeChannels}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:ItemWornTokenRowViewModel">
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
                  <ComboBox Width="140"
                            ItemsSource="{Binding $parent[ItemsControl].((vm:ItemEditorViewModel)DataContext).DyeChannels}"
                            SelectedItem="{Binding Token}" />
                  <Button Content="✕"
                          Command="{Binding $parent[ItemsControl].((vm:ItemEditorViewModel)DataContext).RemoveWornDyeChannelCommand}"
                          CommandParameter="{Binding}" />
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <Button Content="+ Add dye channel" Command="{Binding AddWornDyeChannelCommand}" HorizontalAlignment="Left" />

          <TextBlock Classes="section" Text="Effects" />
          <Grid ColumnDefinitions="140,*" RowDefinitions="Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Classes="field" Text="On use (ability)" />
            <TextBox   Grid.Row="0" Grid.Column="1" Watermark="ability ref" Text="{Binding OnUse}" />
          </Grid>
          <TextBlock Text="On equip" FontWeight="SemiBold" Margin="0,8,0,4" />
          <ItemsControl ItemsSource="{Binding OnEquip}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:ItemOnEquipRowViewModel">
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
                  <TextBox Width="220" Watermark="ability ref" Text="{Binding Ability}" />
                  <Button Content="✕"
                          Command="{Binding $parent[ItemsControl].((vm:ItemEditorViewModel)DataContext).RemoveOnEquipCommand}"
                          CommandParameter="{Binding}" />
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <Button Content="+ Add on-equip effect" Command="{Binding AddOnEquipCommand}" HorizontalAlignment="Left" />

          <TextBlock Classes="section" Text="Price" />
          <Grid ColumnDefinitions="140,*" RowDefinitions="Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Classes="field" Text="Sell / buy (copper)" />
            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="8">
              <TextBox Width="100" Watermark="sell" Text="{Binding PriceSell}" />
              <TextBox Width="100" Watermark="buy" Text="{Binding PriceBuy}" />
            </StackPanel>
          </Grid>

        </StackPanel>
      </ScrollViewer>

      <!-- Live YAML preview — proves the round-trip the CST layer guarantees. -->
      <Border Grid.Column="1" BorderThickness="1,0,0,0"
              BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Text="YAML preview" FontWeight="SemiBold" Margin="8" />
          <ScrollViewer Padding="8">
            <TextBox Text="{Binding PreviewYaml}" IsReadOnly="True" AcceptsReturn="True"
                     FontFamily="Cascadia Code,Menlo,Consolas,monospace" FontSize="12"
                     BorderThickness="0" Background="Transparent" />
          </ScrollViewer>
        </DockPanel>
      </Border>

    </Grid>
  </DockPanel>
</UserControl>
