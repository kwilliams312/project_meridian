<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Meridian.Codex.ViewModels"
             xmlns:edit="using:Meridian.Codex.Editing"
             xmlns:svc="using:Meridian.Codex.Services"
             xmlns:controls="using:Meridian.Codex.Controls"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
             x:Class="Meridian.Codex.Views.PackWorkspaceView"
             x:DataType="vm:PackWorkspaceViewModel">
  <Grid RowDefinitions="*,Auto">
    <ScrollViewer Grid.Row="0" Background="{DynamicResource CodexWorkspaceBrush}">
      <StackPanel Classes="editor-canvas">
      <StackPanel Spacing="4">
        <TextBlock Classes="page-title" Text="Content Pack Workspace" />
        <TextBlock Text="Open a namespace folder or create one under a content root. Codex owns pack.yaml; raw YAML editing is not required."
                   Classes="muted" TextWrapping="Wrap" MaxWidth="720" HorizontalAlignment="Left" />
      </StackPanel>

      <Border x:Name="WorkspaceCard" Classes="card">
        <StackPanel Spacing="10">
          <TextBlock Classes="section" Text="Workspace location" Margin="0,0,0,6" />
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="{Binding DisplayPath}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="0,0,8,0"
                       ToolTip.Tip="{Binding WorkspacePath}"
                       AutomationProperties.Name="Selected pack workspace"
                       AutomationProperties.HelpText="The compact selected workspace path. Use Copy full path for the complete location." />
            <Button Grid.Column="1" Content="Copy full path" Command="{Binding CopyFullPathCommand}"
                    AutomationProperties.Name="Copy full workspace path" />
          </Grid>
          <TextBox IsVisible="{Binding ShowManualWorkspacePath}" Text="{Binding WorkspacePath}"
                   Watermark="Manual content-root or pack-folder path (native folder picker unavailable)"
                   AutomationProperties.Name="Manual pack workspace path"
                   AutomationProperties.HelpText="Fallback path entry used only when this platform has no native folder picker." />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="_Create pack…" Command="{Binding CreateCommand}"
                    AutomationProperties.Name="Create pack in folder"
                    AutomationProperties.HelpText="Choose a content root using the system folder picker, then create the pack." />
            <Button Content="_Open pack…" Command="{Binding OpenCommand}"
                    AutomationProperties.Name="Open pack folder"
                    AutomationProperties.HelpText="Choose a folder containing pack.yaml using the system folder picker." />
          </StackPanel>
          <TextBlock Classes="muted" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
          <ItemsControl ItemsSource="{Binding RecentWorkspaces}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Content="{Binding}" Command="{Binding $parent[UserControl].((vm:PackWorkspaceViewModel)DataContext).OpenRecentCommand}"
                        CommandParameter="{Binding}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        MaxWidth="900" AutomationProperties.HelpText="Open this recent pack workspace." />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <Border x:Name="ManifestCard" Classes="card">
        <StackPanel Spacing="12">
          <TextBlock Classes="section" Text="Manifest" Margin="0,0,0,6" />
          <Grid Classes="form-grid" ColumnDefinitions="176,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
            <TextBlock Grid.Row="0" Classes="field" Text="Namespace" />
            <StackPanel Grid.Row="0" Grid.Column="1"><TextBox Text="{Binding Manifest.Namespace}"/><TextBlock Classes="validation-error" Text="{Binding NamespaceError}"/></StackPanel>
            <TextBlock Grid.Row="1" Classes="field" Text="Name" />
            <StackPanel Grid.Row="1" Grid.Column="1"><TextBox Text="{Binding Manifest.Name}"/><TextBlock Classes="validation-error" Text="{Binding NameError}"/></StackPanel>
            <TextBlock Grid.Row="2" Classes="field" Text="Description" />
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Manifest.Description}" AcceptsReturn="True" MinHeight="76" TextWrapping="Wrap" />
            <TextBlock Grid.Row="3" Classes="field" Text="Pack version" />
            <StackPanel Grid.Row="3" Grid.Column="1"><TextBox Text="{Binding Manifest.Version}"/><TextBlock Classes="validation-error" Text="{Binding VersionError}"/></StackPanel>
            <TextBlock Grid.Row="4" Classes="field" Text="Content schema" />
            <StackPanel Grid.Row="4" Grid.Column="1"><TextBox Text="{Binding Manifest.ContentSchemaVersion}"/><TextBlock Classes="validation-error" Text="{Binding ContentSchemaVersionError}"/></StackPanel>
            <TextBlock Grid.Row="5" Classes="field" Text="Compatibility" />
            <StackPanel Grid.Row="5" Grid.Column="1"><TextBox Text="{Binding Manifest.CompatibilityVersion}"/><TextBlock Classes="validation-error" Text="{Binding CompatibilityVersionError}"/></StackPanel>
            <TextBlock Grid.Row="6" Classes="field" Text="Godot engine pin" />
            <StackPanel Grid.Row="6" Grid.Column="1"><TextBox Text="{Binding Manifest.GodotVersion}"/><TextBlock Classes="validation-error" Text="{Binding GodotVersionError}"/></StackPanel>
            <TextBlock Grid.Row="7" Classes="field" Text="License" />
            <StackPanel Grid.Row="7" Grid.Column="1"><TextBox Text="{Binding Manifest.License}"/><TextBlock Classes="validation-error" Text="{Binding LicenseError}"/></StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <Border Classes="card">
        <StackPanel Spacing="10">
          <TextBlock Classes="section" Text="Dependencies" Margin="0,0,0,0" />
          <TextBlock Classes="muted" Text="Exact version pins loaded with this content pack." />
          <Grid ColumnDefinitions="*,160,Auto">
            <TextBox Margin="0,0,8,0" Text="{Binding NewDependencyNamespace}" Watermark="namespace" />
            <TextBox Grid.Column="1" Margin="0,0,8,0" Text="{Binding NewDependencyVersion}" Watermark="x.y.z" />
            <Button Grid.Column="2" Content="Add dependency" Command="{Binding AddDependencyCommand}" />
          </Grid>
          <ListBox ItemsSource="{Binding Manifest.Dependencies}" SelectedItem="{Binding SelectedDependency}" MinHeight="48">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="edit:PackDependencyData">
                <TextBlock><Run Text="{Binding Namespace}"/><Run Text="  "/><Run Text="{Binding Version}"/></TextBlock>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
          <Button Classes="danger" Content="Remove selected dependency" Command="{Binding RemoveDependencyCommand}" HorizontalAlignment="Left" />
        </StackPanel>
      </Border>

      <Border Classes="card">
        <StackPanel Spacing="6">
          <TextBlock Classes="section" Text="Workspace status" Margin="0,0,0,0" />
          <TextBlock Text="{Binding AggregateStatus}" TextWrapping="Wrap" />
          <ItemsControl ItemsSource="{Binding Diagnostics}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="svc:WorkspaceDiagnostic">
                <TextBlock Classes="validation-error">
                  <Run Text="{Binding Field}"/><Run Text=": "/><Run Text="{Binding Message}"/>
                </TextBlock>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>
      </StackPanel>
    </ScrollViewer>
    <controls:EditorActionBar Grid.Row="1"
                              ActionText="Save manifest"
                              ActionCommand="{Binding SaveCommand}"
                              IsActionEnabled="{Binding CanSave}"
                              StateDescription="{Binding SaveStateDescription}" />
  </Grid>
</UserControl>
