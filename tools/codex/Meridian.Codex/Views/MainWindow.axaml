<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Meridian.Codex.ViewModels"
        xmlns:conv="using:Avalonia.Data.Converters"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="Meridian.Codex.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="900" Height="600"
        Title="{Binding Title}">

  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <DockPanel>

    <Menu DockPanel.Dock="Top">
      <MenuItem Header="_File">
        <MenuItem Header="_New pack" Command="{Binding PackWorkspace.CreateCommand}" />
        <MenuItem Header="_Open pack" Command="{Binding PackWorkspace.OpenCommand}" />
        <MenuItem Header="_Save manifest" Command="{Binding PackWorkspace.SaveCommand}" />
        <Separator />
        <MenuItem Header="E_xit" />
      </MenuItem>
      <MenuItem Header="_Help">
        <MenuItem Header="_Model Info" Command="{Binding ShowModelInfoCommand}" />
      </MenuItem>
    </Menu>

    <Border DockPanel.Dock="Bottom" Padding="8,4"
            Background="{DynamicResource SystemControlBackgroundListLowBrush}">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Text="{Binding PackWorkspace.AggregateStatus}" VerticalAlignment="Center" />
        <TextBlock Grid.Column="1" Text="{Binding PackWorkspace.WorkspaceHeader}" FontWeight="SemiBold" VerticalAlignment="Center" />
      </Grid>
    </Border>

    <!-- Left editor rail + main content. -->
    <Grid ColumnDefinitions="240,*">

      <Border Grid.Column="0" Padding="8"
              Background="{DynamicResource SystemControlBackgroundListLowBrush}">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Text="Editors" FontWeight="Bold" Margin="4,4,4,8" />
          <ListBox ItemsSource="{Binding Editors}"
                   SelectedItem="{Binding SelectedEditor}">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:EditorItem">
                <TextBlock Text="{Binding Name}" />
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>

      <Panel Grid.Column="1">
        <!-- Real editor for the active selection (NPC editor #128); resolved by ViewLocator. -->
        <ContentControl Content="{Binding ActiveEditor}" IsVisible="{Binding ActiveEditor, Converter={x:Static conv:ObjectConverters.IsNotNull}}" />

        <!-- Placeholder for rail entries whose editor has not landed yet. -->
        <StackPanel Margin="24" Spacing="12"
                    IsVisible="{Binding ActiveEditor, Converter={x:Static conv:ObjectConverters.IsNull}}">
          <TextBlock Text="{Binding SelectedEditor.Name}" FontSize="24" FontWeight="SemiBold" />
          <TextBlock Text="{Binding SelectedEditor.Description}" Opacity="0.8" TextWrapping="Wrap" />
          <TextBlock Text="{Binding Greeting}" TextWrapping="Wrap" Margin="0,12,0,0" />
          <Button Content="Show model info" Command="{Binding ShowModelInfoCommand}" />
        </StackPanel>
      </Panel>

    </Grid>

  </DockPanel>

</Window>
