<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Meridian.Codex.ViewModels"
        xmlns:conv="using:Avalonia.Data.Converters"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="Meridian.Codex.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1200" Height="800" MinWidth="760" MinHeight="560"
        Title="{Binding Title}">

  <Window.Styles>
    <Style Selector="ListBox.editor-rail">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBox.editor-rail ListBoxItem">
      <Setter Property="MinHeight" Value="44" />
      <Setter Property="Padding" Value="14,9" />
      <Setter Property="Margin" Value="0,3" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="BorderThickness" Value="3,0,0,0" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ListBox.editor-rail ListBoxItem:selected">
      <Setter Property="BorderBrush" Value="{DynamicResource CodexFocusBrush}" />
    </Style>
    <Style Selector="ListBox.editor-rail ListBoxItem:selected /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource CodexSelectionBrush}" />
    </Style>
  </Window.Styles>

  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+S" Command="{Binding PackWorkspace.SaveCommand}" />
    <KeyBinding Gesture="Meta+S" Command="{Binding PackWorkspace.SaveCommand}" />
  </Window.KeyBindings>

  <DockPanel>

    <Menu DockPanel.Dock="Top" Background="{DynamicResource CodexToolbarBrush}">
      <MenuItem Header="_File">
        <MenuItem Header="_New pack" Command="{Binding PackWorkspace.CreateCommand}" />
        <MenuItem Header="_Open pack" Command="{Binding PackWorkspace.OpenCommand}" />
        <MenuItem Header="_Save manifest" Command="{Binding PackWorkspace.SaveCommand}" />
        <Separator />
        <MenuItem Header="E_xit" />
      </MenuItem>
      <MenuItem Header="_Help">
        <MenuItem Header="_Model Info" Command="{Binding ShowModelInfoCommand}" />
      </MenuItem>
    </Menu>

    <Border DockPanel.Dock="Bottom" Classes="status-bar">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Classes="muted" Text="{Binding PackWorkspace.AggregateStatus}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
        <TextBlock Grid.Column="1" Text="{Binding PackWorkspace.WorkspaceHeader}" FontWeight="SemiBold"
                   VerticalAlignment="Center" Margin="24,0,0,0" />
      </Grid>
    </Border>

    <!-- Left editor rail + main content. -->
    <Grid ColumnDefinitions="240,*">

      <Border x:Name="NavigationZone" Grid.Column="0" Padding="14,20"
              Background="{DynamicResource CodexNavigationBrush}"
              BorderBrush="{DynamicResource CodexBorderSubtleBrush}" BorderThickness="0,0,1,0">
        <DockPanel>
          <StackPanel DockPanel.Dock="Top" Margin="8,0,8,18" Spacing="3">
            <TextBlock Text="MERIDIAN CODEX" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource CodexFocusBrush}" />
            <TextBlock Text="Content authoring" Classes="muted" FontSize="12" />
          </StackPanel>
          <ListBox Classes="editor-rail" ItemsSource="{Binding Editors}"
                   SelectedItem="{Binding SelectedEditor}">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:EditorItem">
                <TextBlock Text="{Binding Name}" />
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>

      <Panel x:Name="WorkspaceZone" Grid.Column="1" Background="{DynamicResource CodexWorkspaceBrush}">
        <!-- Real editor for the active selection (NPC editor #128); resolved by ViewLocator. -->
        <ContentControl Content="{Binding ActiveEditor}" IsVisible="{Binding ActiveEditor, Converter={x:Static conv:ObjectConverters.IsNotNull}}" />

        <!-- Placeholder for rail entries whose editor has not landed yet. -->
        <StackPanel Margin="32" Spacing="12" MaxWidth="720"
                    IsVisible="{Binding ActiveEditor, Converter={x:Static conv:ObjectConverters.IsNull}}">
          <TextBlock Classes="page-title" Text="{Binding SelectedEditor.Name}" />
          <TextBlock Classes="muted" Text="{Binding SelectedEditor.Description}" TextWrapping="Wrap" />
          <TextBlock Text="{Binding Greeting}" TextWrapping="Wrap" Margin="0,12,0,0" />
          <Button Content="Show model info" Command="{Binding ShowModelInfoCommand}" HorizontalAlignment="Left" />
        </StackPanel>
      </Panel>

    </Grid>

  </DockPanel>

</Window>
