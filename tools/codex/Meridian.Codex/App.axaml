<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Meridian.Codex.App"
             xmlns:local="using:Meridian.Codex"
             RequestedThemeVariant="Default">

  <!-- ViewLocator maps a ViewModel instance to its View by naming convention. -->
  <Application.DataTemplates>
    <local:ViewLocator />
  </Application.DataTemplates>

  <Application.Styles>
    <FluentTheme />
  </Application.Styles>

</Application>
