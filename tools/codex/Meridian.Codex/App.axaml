<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Meridian.Codex.App"
             xmlns:local="using:Meridian.Codex"
             RequestedThemeVariant="Dark">

  <Application.Resources>
    <ResourceDictionary>
      <!-- Codex visual-system tokens. Keep semantic roles here so every current
           and schema-generated editor inherits the same accessible contract. -->
      <x:Double x:Key="CodexControlHeight">38</x:Double>
      <x:Double x:Key="CodexLabelWidth">176</x:Double>
      <Thickness x:Key="CodexSpaceXs">4</Thickness>
      <Thickness x:Key="CodexSpaceSm">8</Thickness>
      <Thickness x:Key="CodexSpaceMd">16</Thickness>
      <Thickness x:Key="CodexSpaceLg">24</Thickness>
      <CornerRadius x:Key="CodexRadiusSm">4</CornerRadius>
      <CornerRadius x:Key="CodexRadiusMd">8</CornerRadius>

      <SolidColorBrush x:Key="CodexCanvasBrush" Color="#090F14" />
      <SolidColorBrush x:Key="CodexNavigationBrush" Color="#101A23" />
      <SolidColorBrush x:Key="CodexWorkspaceBrush" Color="#14212B" />
      <SolidColorBrush x:Key="CodexSurfaceBrush" Color="#1D2D39" />
      <SolidColorBrush x:Key="CodexRaisedSurfaceBrush" Color="#263A49" />
      <SolidColorBrush x:Key="CodexToolbarBrush" Color="#192A36" />
      <SolidColorBrush x:Key="CodexActionBrush" Color="#203543" />
      <SolidColorBrush x:Key="CodexPreviewBrush" Color="#0C161D" />
      <SolidColorBrush x:Key="CodexInputBrush" Color="#0D1820" />
      <SolidColorBrush x:Key="CodexBorderBrush" Color="#607A8D" />
      <SolidColorBrush x:Key="CodexBorderSubtleBrush" Color="#3B5363" />
      <SolidColorBrush x:Key="CodexTextBrush" Color="#F4F8FA" />
      <SolidColorBrush x:Key="CodexMutedTextBrush" Color="#C2CED6" />
      <SolidColorBrush x:Key="CodexDisabledTextBrush" Color="#B0BBC2" />
      <SolidColorBrush x:Key="CodexAccentBrush" Color="#1476A8" />
      <SolidColorBrush x:Key="CodexAccentHoverBrush" Color="#1B84B5" />
      <SolidColorBrush x:Key="CodexAccentPressedBrush" Color="#0E5B82" />
      <SolidColorBrush x:Key="CodexFocusBrush" Color="#82D5FA" />
      <SolidColorBrush x:Key="CodexErrorBrush" Color="#FFAAA8" />
      <SolidColorBrush x:Key="CodexErrorSurfaceBrush" Color="#49272B" />
      <SolidColorBrush x:Key="CodexSuccessBrush" Color="#78DDA2" />
      <SolidColorBrush x:Key="CodexWarningBrush" Color="#F3C56D" />
      <SolidColorBrush x:Key="CodexSelectionBrush" Color="#244B60" />
    </ResourceDictionary>
  </Application.Resources>

  <!-- ViewLocator maps a ViewModel instance to its View by naming convention. -->
  <Application.DataTemplates>
    <local:ViewLocator />
  </Application.DataTemplates>

  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="/Styles/CodexTheme.axaml" />
  </Application.Styles>

</Application>
