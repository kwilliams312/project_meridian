<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Meridian.Codex.Models — the typed content model for the Codex editor
    (Tools SAD §6.1: "Models/ generated from /schema/content, same generator as
    mcc's structs, C# target").

    This project does NOT hand-author models. It CONSUMES the single generated
    artifact produced by the schema-driven generator (tools/schema_gen, whose C#
    emitter is tools/schema_gen/emit_csharp.py) from the /schema/content source of
    truth. The generated file is linked in below; VerifyContentModels proves it is
    current before every compile. A missing or broken Python toolchain fails the
    build instead of silently compiling a stale checked-in artifact.
  -->
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <LangVersion>12</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RollForward>Major</RollForward>
    <RootNamespace>Meridian.Codex.Models</RootNamespace>
    <AssemblyName>Meridian.Codex.Models</AssemblyName>
    <!-- Generated file carries its own doc comments; don't fail on the few that are absent. -->
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <!--
    Consume the canonical generated file directly (no fork, no copy). The IR +
    emitter live in tools/schema_gen; the output lands here and is compiled as if
    it were a source file of this project.
  -->
  <ItemGroup>
    <Compile Include="$(MSBuildProjectDirectory)/../../schema_gen/generated/csharp/ContentTypes.g.cs"
             Link="Generated/ContentTypes.g.cs" />
  </ItemGroup>

  <!--
    Verify the checked-in models against /schema/content before compiling. This is
    intentionally fail-closed: generation/toolchain/cache failures and output drift
    must stop the build. Regeneration is an explicit developer action documented in
    tools/codex/README.md. Repo root is three levels up from this project directory.
  -->
  <Target Name="VerifyContentModels" BeforeTargets="CoreCompile">
    <PropertyGroup>
      <_RepoRoot>$(MSBuildProjectDirectory)/../../..</_RepoRoot>
    </PropertyGroup>
    <Exec Command="uv run python -m tools.schema_gen --check"
          WorkingDirectory="$(_RepoRoot)" />
  </Target>

</Project>
