          }
        },
        {
          "path": "presets.face[].texture",
          "ui": {
            "group": "customization",
            "label": "Face texture",
            "widget": "asset_picker",
            "reference_type": "asset:art"
          },
          "asset": {
            "allowed_classes": [
              "texture_set"
            ],
            "eligible_generators": []
          }
        },
        {
          "path": "presets.skin[].palette",
          "ui": {
            "group": "customization",
            "label": "Skin palette",
            "widget": "asset_picker",
            "reference_type": "asset:art"
          },
          "asset": {
            "allowed_classes": [
              "texture_set"
            ],
            "eligible_generators": []
