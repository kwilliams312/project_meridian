    {
      "schema_file": "asset.schema.yaml",
      "schema_id": "meridian://schema/content/asset.schema.yaml",
      "content_schema": "meridian/asset@1",
      "fields": []
    },
    {
      "schema_file": "appearance.schema.yaml",
      "schema_id": "meridian://schema/content/appearance.schema.yaml",
      "content_schema": "meridian/appearance_catalog@1",
      "fields": [
        {
          "path": "skeleton",
          "ui": {
            "group": "body",
            "label": "Reference skeleton",
            "widget": "asset_picker",
            "reference_type": "asset:art",
            "help": "Canonical rig used by every body and wearable in this appearance catalog."
          },
          "asset": {
            "allowed_classes": [
              "character_model"
            ],
            "eligible_generators": []
          }
        },
        {
          "path": "body_model",
          "ui": {
            "group": "body",
            "label": "Character body model",
            "widget": "asset_picker",
            "reference_type": "asset:art"
          },
          "asset": {
