          }
        },
        {
          "path": "cooldown_ms",
          "ui": {
            "group": "timing",
            "label": "Cooldown",
            "widget": "number",
            "unit": "ms"
          }
        },
        {
          "path": "audio_visual",
          "ui": {
            "group": "presentation",
            "label": "Audio and visual"
          }
        },
        {
          "path": "audio_visual.cast_anim",
          "ui": {
            "group": "presentation",
            "label": "Cast animation",
            "widget": "animation"
          }
        },
        {
          "path": "audio_visual.cast_vfx",
          "ui": {
            "group": "presentation",
            "label": "Cast VFX",
            "widget": "asset_picker",
            "reference_type": "asset:art"
          },
          "asset": {
            "allowed_classes": [
              "vfx"
            ],
            "eligible_generators": []
          }
        },
        {
          "path": "audio_visual.cast_sfx",
          "ui": {
            "group": "presentation",
            "label": "Cast SFX",
            "widget": "asset_picker",
            "reference_type": "asset:sfx"
          },
          "asset": {
            "allowed_classes": [
              "sfx"
            ],
            "eligible_generators": []
          }
        },
        {
          "path": "audio_visual.impact_vfx",
          "ui": {
            "group": "presentation",
            "label": "Impact VFX",
            "widget": "asset_picker",
            "reference_type": "asset:art"
          },
          "asset": {
            "allowed_classes": [
              "vfx"
            ],
            "eligible_generators": []
          }
        },
        {
          "path": "audio_visual.impact_sfx",
          "ui": {
            "group": "presentation",
            "label": "Impact SFX",
            "widget": "asset_picker",
            "reference_type": "asset:sfx"
          },
          "asset": {
            "allowed_classes": [
              "sfx"
            ],
            "eligible_generators": []
          }
        }
      ]
    },
    {
      "schema_file": "quest.schema.yaml",
      "schema_id": "meridian://schema/content/quest.schema.yaml",
      "content_schema": "meridian/quest@1",
      "fields": []
