# Keep the Docker build context lean (#176). The server image build only needs
# schema/ + server/ (see deploy/docker/Dockerfile COPY lines); everything else
# is excluded so it neither bloats the context nor invalidates the build cache.
.git
.github
client
content
docs
tests
tools
scripts
deploy
*.md
uv.lock
pyproject.toml

# Never ship build trees or local certs into an image context.
**/build/
server/build/
deploy/docker/certs/*.crt
deploy/docker/certs/*.key
deploy/docker/certs/*.pem

# Editor / OS noise
.DS_Store
__pycache__/
*.pyc
