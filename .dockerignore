# Keep the Docker build context lean (#176). The daemon image build needs
# schema/ + server/ (deploy/docker/Dockerfile COPY lines); the meridian-db image
# (deploy/docker/Dockerfile.db) also needs the db-init wrappers, so deploy/ is
# excluded EXCEPT deploy/docker/db-init. Everything else is excluded so it
# neither bloats the context nor invalidates the build cache.
.git
.github
client
!client
client/godot-cpp
content
docs
tests
tools
scripts
deploy
!deploy/docker/db-init
*.md
uv.lock
pyproject.toml

# Never ship build trees or local certs into an image context.
**/build/
server/build/
deploy/docker/certs/*.crt
deploy/docker/certs/*.key
deploy/docker/certs/*.pem

# Editor / OS noise
.DS_Store
__pycache__/
*.pyc
