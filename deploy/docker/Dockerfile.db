# syntax=docker/dockerfile:1.7
# SPDX-License-Identifier: Apache-2.0
#
# meridian-db — MariaDB 11 that self-seeds the 3-DB split (auth / characters /
# world) on first boot. The db-init wrappers (deploy/docker/db-init/*.sql) run
# alphabetically from /docker-entrypoint-initdb.d and SOURCE the real schema
# from /schemas/{auth,characters,world}. Baking the schema into the image keeps
# it source-of-truth in-repo (server/db/*, schema/sql/world) while letting both
# compose and the Helm chart consume one seeded image. Build context = repo root.

# ── Content stage (#482): compile the world/CONTENT DB DML from /content ─────
# The world schema is baked as EMPTY template tables (03-world.sql). worldd,
# however, needs the mcc-emitted CONTENT rows (npc/quest/loot/vendor/item +
# abilities — the #390 DB stores + #483 DbAbilityStore) or the realm serves zero
# content. We compile that DML HERE with the same mcc the golden gate uses
# (`mcc emit-sql content`, INSERT-only, deterministic; needs only the content
# tree — no rendered client assets) and bake the result into the image so the
# content version travels in lockstep with the world schema + the image tag. The
# Helm content-seed Job (deploy/helm/meridian/templates/world-content-seed.yaml)
# loads it into meridian_world on deploy.
FROM debian:bookworm-slim AS content
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential cmake ninja-build g++ git ca-certificates \
    && rm -rf /var/lib/apt/lists/*
WORKDIR /src
# mcc's only external dep is yaml-cpp (system package or a pinned FetchContent
# fallback fetched over git); the content tree carries the committed idmap.lock
# emit-sql resolves ids against read-only.
COPY tools/mcc/ ./tools/mcc/
COPY content/   ./content/
# mcc's CMake resolves schema/chunk/chunk.fbs (flatc --cpp -> chunk_generated.h,
# a hard dep of the mcc target) plus schema/sql/world + schema/chunk/
# chunk-manifest.schema.yaml at configure time (tools/mcc/CMakeLists.txt). Copy
# the whole schema/ dir — it is the in-repo schema source-of-truth and small
# (#811); without it the mcc build fails on the missing chunk.fbs.
COPY schema/    ./schema/
RUN cmake -S tools/mcc -B tools/mcc/build -G Ninja -DCMAKE_BUILD_TYPE=Release \
    && cmake --build tools/mcc/build --target mcc
# Emit the world-DB content DML (IF-4 world_manifest + the content INSERTs).
# --pack core: after the chibi theme pack (content/chibi) merged, an unpinned
# `emit-sql content` emits BOTH packs' rosters into one world DB, whose per-pack
# roster_id PKs collide on load (story #770/#803). Each realm loads exactly ONE
# pack (design 2026-07-14-chibi §4), so bake a single-pack world DB PER theme:
#   * /world-content.sql        — the default `core` realm content (ptr/prod), and
#   * /world-content-chibi.sql  — the `chibi` theme the dev realm loads (C9/#762);
#     the dev overlay points mariadb.contentSeed.sqlPath at it.
# The chibi bake is guarded so the image still builds on a core-only tree (e.g. a
# checkout that predates the chibi pack); a realm only ever seeds the file its
# overlay selects, so an absent chibi file is inert for a core realm.
RUN tools/mcc/build/mcc emit-sql content --pack core --out /world-content.sql \
    && if [ -d content/chibi ]; then \
         tools/mcc/build/mcc emit-sql content --pack chibi --out /world-content-chibi.sql; \
       else \
         echo "content/chibi absent — skipping chibi world DB bake"; \
         : > /world-content-chibi.sql; \
       fi

# ── Runtime stage: MariaDB 11 with the baked schema + content ────────────────
FROM mariadb:11

# The first-boot init wrappers (CREATE DATABASE + SOURCE the migrations + grants).
COPY deploy/docker/db-init/*.sql /docker-entrypoint-initdb.d/

# The schema the wrappers SOURCE, at the exact paths they reference.
COPY server/db/auth/migrations/          /schemas/auth/
COPY server/db/characters/migrations/    /schemas/characters/
COPY schema/sql/world/                    /schemas/world/

# The deploy-time character-DB migration runner (#815). initdb (02-characters.sql)
# applies + tracks every migration on a FRESH datadir; but a PERSISTENT realm's
# datadir survives, so a migration added after first init never lands there. The
# Helm PreSync hook Job (deploy/helm/meridian/templates/characters-db-migrate.yaml)
# runs THIS script — before worldd rolls — to apply the un-applied *.up.sql from
# /schemas/characters to an already-initialized meridian_characters, additively,
# tracked in schema_migrations. mariadb client is already present in the base image.
COPY deploy/docker/char-migrate.sh /usr/local/bin/meridian-char-migrate
RUN chmod +x /usr/local/bin/meridian-char-migrate

# The mcc-emitted world CONTENT DML (#482) — applied to meridian_world by the
# Helm content-seed Job on deploy (NOT auto-loaded on first boot, so the same
# image serves both the ephemeral dev DB and the persistent PTR/Prod DBs; the
# Job refreshes content idempotently on every deploy/promotion).
COPY --from=content /world-content.sql /content/world-content.sql
# The chibi theme's single-pack world DB (C9/#762) — the dev realm's content-seed
# Job loads THIS instead of the core one (dev overlay contentSeed.sqlPath). Empty
# on a core-only tree (the guarded bake above); inert unless a realm selects it.
COPY --from=content /world-content-chibi.sql /content/world-content-chibi.sql
